# Application
EVE_ENV=development
EVE_LOG_LEVEL=INFO
EVE_PUBLIC_BASE_URL=http://localhost:8000
EVE_API_BASE_URL=http://localhost:8001

# Database
EVE_DATABASE_URL=postgresql+asyncpg://eve:eve_dev_password@127.0.0.1:5432/eve_dev

# Redis / Celery
EVE_REDIS_URL=redis://127.0.0.1:6379/0
EVE_CELERY_BROKER_URL=redis://127.0.0.1:6379/1
EVE_CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# Vault
EVE_VAULT_ADDR=http://127.0.0.1:8200
EVE_VAULT_TOKEN=eve-dev-root-token
EVE_VAULT_MOUNT=eve

# Security
EVE_COOKIE_SECURE=false
EVE_AUTH_SECRET_KEY=eve-development-auth-signing-key-change-before-production
EVE_ACCESS_TOKEN_TTL_SECONDS=900
EVE_REFRESH_TOKEN_TTL_SECONDS=2592000
EVE_LICENSE_PUBLIC_KEY=

# Built-in Intelligence Sources
EVE_NVD_API_KEY=
EVE_SEARCHSPLOIT_METADATA_INDEX_PATH=/var/lib/eve/searchsploit-metadata.json
